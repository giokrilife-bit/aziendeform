import { useState, useEffect, useMemo } from "react";

// ─── SCORING ENGINE ────────────────────────────────────────────────────────────
function computeScore(r) {
  let score = 0;
  // Soddisfazione dipendenti (Q3, scala 1-5)
  score += (r.soddisfazione || 0) * 6; // max 30
  // Difficoltà trattenere personale
  const turnoverMap = { "Sì, spesso": 15, "A volte": 8, "No": 0 };
  score += turnoverMap[r.difficolta] || 0;
  // Welfare attuale (chi ha già welfare strutturato = più ricettivo)
  const welfareMap = { "No": 5, "Sì, minimo (bonus occasionali)": 12, "Sì, strutturato": 4 };
  score += welfareMap[r.welfareAttuale] || 0;
  // Importanza benessere (Q7, scala 1-5)
  score += (r.importanzaBenessere || 0) * 7; // max 35
  // Interesse soluzioni
  const interesseMap = { "Sì": 15, "Forse": 7, "No": 0 };
  score += interesseMap[r.interesseSoluzioni] || 0;
  // Obiettivo (fidelizzare = massimo interesse)
  const obiettivoMap = { "Fidelizzare dipendenti": 5, "Aumentare produttività": 4, "Crescere organico": 3, "Ridurre costi": 2, "Altro": 1 };
  score += obiettivoMap[r.obiettivo] || 0;
  return Math.min(100, Math.round(score));
}

function computePropensione(r) {
  const dim = r.dipendenti;
  let base = dim === "50+" ? 80 : dim === "21–50" ? 65 : dim === "6–20" ? 45 : 30;
  if (r.interesseSoluzioni === "Sì") base += 15;
  if (r.welfareAttuale === "No") base -= 10;
  return Math.min(100, Math.max(0, base));
}

function computeProbabilita(score, propensione) {
  return Math.min(100, Math.round((score * 0.6 + propensione * 0.4)));
}

// ─── STORAGE ──────────────────────────────────────────────────────────────────
const STORAGE_KEY = "welfare_risposte_v1";

async function loadRisposte() {
  try {
    const res = await window.storage.get(STORAGE_KEY);
    return res ? JSON.parse(res.value) : [];
  } catch {
    return [];
  }
}

async function saveRisposte(list) {
  try {
    await window.storage.set(STORAGE_KEY, JSON.stringify(list));
  } catch {}
}

