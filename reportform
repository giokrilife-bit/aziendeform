// ─── UI ATOMS ─────────────────────────────────────────────────────────────────
function Card({ children, style = {} }) {
  return (
    <div style={{
      background: CLR.bg,
      border: `0.5px solid ${CLR.border}`,
      borderRadius: 12,
      padding: "1.25rem",
      ...style,
    }}>{children}</div>
  );
}

function Badge({ children, color = "primary" }) {
  const map = {
    primary: [CLR.primaryLight, CLR.primary],
    success: [CLR.successLight, CLR.success],
    warn: [CLR.warnLight, CLR.warn],
    danger: [CLR.dangerLight, CLR.danger],
    accent: [CLR.accentLight, CLR.accent],
  };
  const [bg, fg] = map[color] || map.primary;
  return (
    <span style={{
      background: bg, color: fg,
      fontSize: 11, fontWeight: 500,
      padding: "3px 10px", borderRadius: 20,
      display: "inline-block",
    }}>{children}</span>
  );
}

function ScoreBar({ value, color = CLR.primary }) {
  return (
    <div style={{ position: "relative", height: 8, background: CLR.bgSecondary, borderRadius: 4, overflow: "hidden" }}>
      <div style={{ width: `${value}%`, height: "100%", background: color, borderRadius: 4, transition: "width 0.8s ease" }} />
    </div>
  );
}

function MetricCard({ label, value, unit = "", color = CLR.primary }) {
  return (
    <div style={{ background: CLR.bgSecondary, borderRadius: 8, padding: "0.75rem 1rem" }}>
      <p style={{ fontSize: 12, color: CLR.textMuted, margin: "0 0 4px" }}>{label}</p>
      <p style={{ fontSize: 22, fontWeight: 500, color, margin: 0 }}>{value}<span style={{ fontSize: 13, marginLeft: 3 }}>{unit}</span></p>
    </div>
  );
}

// ─── FORM STEP COMPONENTS ─────────────────────────────────────────────────────
function Radio({ label, value, selected, onChange }) {
  const active = selected === value;
  return (
    <label style={{
      display: "flex", alignItems: "center", gap: 10,
      padding: "10px 14px", borderRadius: 8, cursor: "pointer",
      border: `1.5px solid ${active ? CLR.primary : CLR.border}`,
      background: active ? CLR.primaryLight : "transparent",
      transition: "all 0.15s",
    }}>
      <input type="radio" style={{ display: "none" }} checked={active} onChange={() => onChange(value)} />
      <span style={{
        width: 16, height: 16, borderRadius: "50%",
        border: `2px solid ${active ? CLR.primary : "#aaa"}`,
        background: active ? CLR.primary : "transparent",
        display: "flex", alignItems: "center", justifyContent: "center",
        flexShrink: 0,
      }}>
        {active && <span style={{ width: 6, height: 6, borderRadius: "50%", background: "#fff" }} />}
      </span>
      <span style={{ fontSize: 14, color: CLR.text }}>{value}</span>
    </label>
  );
}

function Checkbox({ label, value, checked, onChange }) {
  return (
    <label style={{
      display: "flex", alignItems: "center", gap: 10,
      padding: "10px 14px", borderRadius: 8, cursor: "pointer",
      border: `1.5px solid ${checked ? CLR.accent : CLR.border}`,
      background: checked ? CLR.accentLight : "transparent",
      transition: "all 0.15s",
    }}>
      <input type="checkbox" style={{ display: "none" }} checked={checked} onChange={() => onChange(value)} />
      <span style={{
        width: 16, height: 16, borderRadius: 4,
        border: `2px solid ${checked ? CLR.accent : "#aaa"}`,
        background: checked ? CLR.accent : "transparent",
        display: "flex", alignItems: "center", justifyContent: "center",
        flexShrink: 0,
      }}>
        {checked && <span style={{ color: "#fff", fontSize: 11, fontWeight: 700 }}>✓</span>}
      </span>
      <span style={{ fontSize: 14, color: CLR.text }}>{value}</span>
    </label>
  );
}

function StarScale({ value, onChange, max = 5 }) {
  return (
    <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
      {Array.from({ length: max }, (_, i) => i + 1).map(n => (
        <button key={n} onClick={() => onChange(n)} style={{
          width: 44, height: 44, borderRadius: 8, border: `1.5px solid ${n <= value ? CLR.primary : CLR.border}`,
          background: n <= value ? CLR.primary : "transparent",
          color: n <= value ? "#fff" : CLR.textMuted,
          fontWeight: 500, fontSize: 15, cursor: "pointer",
          transition: "all 0.15s",
        }}>{n}</button>
      ))}
      <span style={{ fontSize: 13, color: CLR.textMuted, alignSelf: "center", marginLeft: 4 }}>
        {value ? `${value} / ${max}` : "seleziona"}
      </span>
    </div>
  );
}

